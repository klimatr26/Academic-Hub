{
  "expo": {
    "name": "Academic Hub",
    "slug": "academic-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050608"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Academic Hub usa el microfono para grabar notas de voz en tus tareas.",
        "NSPhotoLibraryUsageDescription": "Academic Hub usa tus fotos para adjuntar imagenes a tus tareas."
      }
    },
    "android": {
      "package": "com.ihc.academichub",
      "permissions": [
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050608"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "d7ac39ca-4326-4ff0-9c7d-84a36ab0727c"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-audio",
      "expo-asset",
      "react-native-edge-to-edge",
      "@react-native-community/datetimepicker"
    ]
  }
}
